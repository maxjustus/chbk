# chbk environment configuration
#
# Copy to .env.
# Generate this file: chbk generate-env > .env
#
# Precedence (highest wins):
#   CLI flag > environment variable > .env file > default

# ── ClickHouse ────────────────────────────────────────────────────────

# CH_URL=http://localhost:8123
# CH_USER=default
# CH_PASSWORD=
# CH_DATA_PATH=/var/lib/clickhouse
# CH_USE_LOCAL=false
# CH_CONFIG_PATH=/path/to/config.xml
# CH_SHARD=shard1
# CH_REPLICA=replica1

# ── S3 Storage ────────────────────────────────────────────────────────

# S3_BUCKET=my-backup-bucket
# S3_REGION=us-east-1
# S3_ENDPOINT=http://minio:9000
# S3_ACCESS_KEY_ID=AKIA...
# S3_SECRET_ACCESS_KEY=...
# S3_PREFIX=backups/

# ── Backup ────────────────────────────────────────────────────────────

# BACKUP_DIR=./backup
# CHBK_IGNORE=^system\.
# CHBK_ONLY=^production\.

# ── Tuning ────────────────────────────────────────────────────────────

# PART_CONCURRENCY=8
# MULTIPART_PART_CONCURRENCY=16
# DELETE_CONCURRENCY=32
# UPLOAD_MIN_CHUNK_SIZE_MB=16
# UPLOAD_MAX_CHUNK_SIZE_MB=512
# UPLOAD_TARGET_PARTS=128
